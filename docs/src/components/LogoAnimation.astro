<script>
  import { createTimeline, svg } from "animejs";

  const vizPaths = [...document.querySelectorAll(".vizb-hero .viz-path")];
  const barRefs = [...document.querySelectorAll(".bar-ref")];
  const lineRefs = [...document.querySelectorAll(".line-ref")];
  const pieRefs = [...document.querySelectorAll(".pie-ref")];
  const logoRefs = [...document.querySelectorAll(".logo-ref")];

  const PAUSE = 2750;
  const DUR = 400;

  const tl = createTimeline({ loop: true });

  vizPaths.forEach((p, i) => {
    tl.set(p, { d: svg.morphTo(logoRefs[i]) }, 0);
  });

  const phases = [
    { refs: barRefs, label: "bar" },
    { refs: lineRefs, label: "line" },
    { refs: pieRefs, label: "pie" },
    { refs: logoRefs, label: "logo" },
  ];

  for (const { refs, label } of phases) {
    tl.label(label, `+=${PAUSE}`);
    vizPaths.forEach((p, i) => {
      tl.add(
        p,
        {
          d: svg.morphTo(refs[i]),
          duration: DUR,
          ease: "inOutCubic",
        },
        label,
      );
    });
  }
</script>
